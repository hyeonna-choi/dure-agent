# API keys for the LLM agents. Copy this file to `.env` and fill in your keys,
# or export these variables in your shell. No keys are hard-coded in the source.

# Anthropic (default Validation Agent: claude-sonnet-4-6)
ANTHROPIC_API_KEY=
# Some modules also accept CLAUDE_API_KEY as an alias.
CLAUDE_API_KEY=

# OpenAI (GPT-5 / GPT-4.1 / o4-mini Parser Agents)
OPENAI_API_KEY=

# Together AI (open-weight Llama models, OpenAI-compatible endpoint)
LLAMA_API_KEY=

# Optional: override the Claude max output tokens (default 2048)
# CLAUDE_MAX_TOKENS=2048
